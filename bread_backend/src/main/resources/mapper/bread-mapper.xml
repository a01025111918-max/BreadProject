<?xml version="1.0" encoding="UTF-8"?>
<!--<?xml version="1.0" encoding="UTF-8"?>은 무조건 선랭되어야 함-->
<!DOCTYPE mapper PUBLIC "-//mybatis.org//DTD Mapper 3.0//EN" "http://mybatis.org/dtd/mybatis-3-mapper.dtd">

<mapper namespace="com.example.Bread_project.bread.dao.BreadDao">
    <!--빵 전체조회-->
    <select id="selectBreadList" resultType="bread">
        select *
        from bread_tbl
        order by bread_no desc
    </select>

    <!--빵상세조회-->
    <select id="selectOneBread" resultType="bread">
        select *
        from bread_tbl
        where bread_no = #{breadNo}
    </select>

    <!--빵 영양 상세 조회 -->
    <select id="selectOneNutrition" resultType="breadDetail">
        select detail_id,
               bread_no,
               serving_size,
               calories_kcal,
               carbohydrate_g,
               sugar_g,
               protein_g,
               fat_g,
               sodium_mg,
               ingredients,
               allergy_info,
               detail_description,
               created_at
        from bread_detail_tbl
        where bread_no = #{breadNo}

    </select>
</mapper>